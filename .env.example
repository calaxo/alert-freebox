# URL to probe every 5 minutes (your Freebox's dynamic DNS address or any HTTP/HTTPS endpoint)
HOST_URL=https://votredomaine.dyndns.org

# Free Mobile account ID (visible in Mon Compte > Mes Options > Notifications par SMS)
# Note: do not name this variable USER in your shell environment — USER is a reserved
# system variable on Linux. Define it explicitly in this .env file.
USER=12345678

# Free Mobile SMS API key (generated in the same section as above)
PASS=XXXXXXXXXXXXXXXXXX

# Port the Express server listens on (default: 3000)
PORT=3000
